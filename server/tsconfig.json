{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../src/online/protocol.ts",
    "../src/types.ts",
    "../src/engine/**/*.ts",
    "../src/data/dbBuild.ts",
    "../src/data/newgenNames.ts",
    "../src/data/faPool.ts"
  ]
}
